# --- Domain ---
# Used for reference/docs. Actual subdomain routing (dashboard.rydberg.app,
# api.rydberg.app, etc.) is configured in the Cloudflare Zero Trust dashboard
# for your tunnel, not read directly from this file.
BASE_DOMAIN=rydberg.app

# --- Cloudflare Tunnel ---
# Zero Trust > Networks > Tunnels > your tunnel > install/token
CLOUDFLARE_TUNNEL_TOKEN=
#!/usr/bin/env bash
# rydberg — install and run Rydberg modules from a thin core repo.
#
# Usage:
#   rydberg install <name> [git-url] [ref]   Install an official module by name,
#                                            or a custom one by URL
#   rydberg catalog                          List official modules you can install by name
#   rydberg remove <name>                    Remove a module
#   rydberg update [<name>]                  git pull one module, or all
#   rydberg list                             Show installed modules
#   rydberg up [<name>...]                   Generate compose + start (all, or named subset)
#   rydberg down                             Stop everything
#   rydberg restart [<name>...]              Restart everything, or named service(s)
#   rydberg status                           Show container status (docker compose ps)
#   rydberg logs <name> [-f]                 Tail logs for one service (-f to follow)
#   rydberg doctor                           Check prerequisites (docker, network, .env)
#   rydberg self-install [path]              Symlink this script onto your PATH
#                                            (default: /usr/local/bin/rydberg)
#
set -euo pipefail

# Resolve the real location of this script, following symlinks (needed
# since `self-install` symlinks this file to somewhere like /usr/local/bin —
# without this, ROOT would resolve to /usr/local instead of the repo).
SOURCE="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
APPS_DIR="$ROOT/apps"
REGISTRY="$ROOT/modules.list"
CATALOG="$ROOT/catalog.list"
GENERATED="$ROOT/docker-compose.generated.yml"

mkdir -p "$APPS_DIR"
touch "$REGISTRY" "$CATALOG"

usage() {
  sed -n '2,10p' "$0"
  exit 1
}

# --- registry helpers -------------------------------------------------
# modules.list format: one line per module, space-separated:
#   <name> <git-url> <ref>
registry_add() {
  local name="$1" url="$2" ref="$3"
  registry_remove "$name" || true
  echo "$name $url $ref" >> "$REGISTRY"
}

registry_remove() {
  local name="$1"
  grep -v "^$name " "$REGISTRY" > "$REGISTRY.tmp" 2>/dev/null || true
  mv -f "$REGISTRY.tmp" "$REGISTRY" 2>/dev/null || true
}

registry_list() {
  [ -s "$REGISTRY" ] || { echo "No modules installed yet."; return; }
  printf "%-15s %-50s %s\n" "NAME" "REPO" "REF"
  while read -r name url ref; do
    printf "%-15s %-50s %s\n" "$name" "$url" "$ref"
  done < "$REGISTRY"
}

catalog_lookup() {
  local name="$1"
  grep "^$name " "$CATALOG" 2>/dev/null | head -1
}

cmd_catalog() {
  [ -s "$CATALOG" ] || { echo "Catalog is empty."; return; }
  echo "Official modules (install with: rydberg install <name>):"
  printf "%-15s %-55s %s\n" "NAME" "REPO" "REF"
  grep -v '^#' "$CATALOG" | grep -v '^\s*$' | while read -r name url ref; do
    printf "%-15s %-55s %s\n" "$name" "$url" "$ref"
  done
}

# --- commands -----------------------------------------------------------
cmd_install() {
  local name="${1:?module name required}"
  local url="${2:-}"
  local ref="${3:-main}"

  if [ -z "$url" ]; then
    local found
    found="$(catalog_lookup "$name")"
    if [ -z "$found" ]; then
      echo "'$name' isn't an official module and no URL was given."
      echo "See official modules: rydberg catalog"
      echo "Or install a custom one: rydberg install <name> <git-url> [ref]"
      exit 1
    fi
    url="$(echo "$found" | awk '{print $2}')"
    ref="$(echo "$found" | awk '{print $3}')"
    [ -n "$ref" ] || ref="main"
  fi

  if [ -d "$APPS_DIR/$name" ]; then
    echo "Module '$name' already installed at apps/$name. Use 'rydberg update $name' instead."
    exit 1
  fi
  echo "Cloning $url (ref: $ref) into apps/$name ..."
  git clone --branch "$ref" --single-branch "$url" "$APPS_DIR/$name"

  # If the module declares its own canonical name (.rydberg-module file at
  # its root), check it matches what you installed it as — catches typos
  # like installing "portfolio" from a repo that actually calls itself
  # something else, before it causes confusing profile/routing mismatches.
  local declared_file="$APPS_DIR/$name/.rydberg-module"
  if [ -f "$declared_file" ]; then
    local declared
    declared="$(tr -d '[:space:]' < "$declared_file")"
    if [ -n "$declared" ] && [ "$declared" != "$name" ]; then
      echo "  [warn] this module calls itself '$declared' in .rydberg-module,"
      echo "         but you installed it as '$name'. Its compose profiles"
      echo "         likely use '$declared' — you may need:"
      echo "           rydberg up $declared"
      echo "         instead of '$name', or reinstall using the declared name."
    fi
  fi

  registry_add "$name" "$url" "$ref"
  echo "Installed '$name'. Run 'rydberg up' to include it."
}

cmd_remove() {
  local name="${1:?module name required}"
  read -rp "Remove apps/$name and its registry entry? [y/N] " confirm
  [ "$confirm" = "y" ] || { echo "Aborted."; exit 0; }
  rm -rf "${APPS_DIR:?}/$name"
  registry_remove "$name"
  echo "Removed '$name'."
}

cmd_update() {
  local target="${1:-}"
  while read -r name url ref; do
    if [ -n "$target" ] && [ "$target" != "$name" ]; then continue; fi
    echo "Updating $name ..."
    (cd "$APPS_DIR/$name" && git fetch origin "$ref" && git checkout "$ref" && git pull origin "$ref")
  done < "$REGISTRY"
}

cmd_list() {
  registry_list
}

# Generate docker-compose.generated.yml: core compose files + each
# installed module's docker-compose.yml, via Compose's `include:`.
generate_compose() {
  {
    echo "# AUTO-GENERATED by bin/rydberg — do not edit by hand."
    echo "include:"
    for f in "$ROOT"/compose/*.yml; do
      [ -e "$f" ] || continue
      echo "  - ${f#"$ROOT"/}"
    done
    while read -r name _url _ref; do
      [ -f "$APPS_DIR/$name/docker-compose.yml" ] && \
        echo "  - apps/$name/docker-compose.yml"
    done < "$REGISTRY"
  } > "$GENERATED"
}

cmd_up() {
  generate_compose
  # --profile is a top-level `docker compose` flag and must come BEFORE
  # the `up` subcommand. Separate it from plain name arguments.
  local top_flags=() name_args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --profile) top_flags+=("--profile" "${2:?--profile needs a value}"); shift 2 ;;
      --profile=*) top_flags+=("$1"); shift ;;
      *) name_args+=("$1"); shift ;;
    esac
  done

  # Split plain name arguments into "known installed module" (treated as
  # a profile to activate — e.g. `rydberg up dashboard`) vs. anything else
  # (treated as a literal compose service name, forwarded after `up -d`).
  local module_flags=() svc_args=()
  for arg in "${name_args[@]}"; do
    if grep -q "^$arg " "$REGISTRY" 2>/dev/null; then
      module_flags+=("--profile" "$arg")
    else
      svc_args+=("$arg")
    fi
  done

  # No specific module named -> default to EVERY installed module, so a
  # bare `rydberg up` actually starts what you've installed, not just
  # profile-less core infra like cloudflared.
  if [ "${#module_flags[@]}" -eq 0 ] && [ "${#svc_args[@]}" -eq 0 ]; then
    while read -r name _url _ref; do
      module_flags+=("--profile" "$name")
    done < "$REGISTRY"
  fi

  echo "Generated $GENERATED:"
  cat "$GENERATED"
  echo
  docker compose -f "$GENERATED" "${module_flags[@]}" "${top_flags[@]}" up -d "${svc_args[@]}"
}

cmd_down() {
  [ -f "$GENERATED" ] || { echo "Nothing to stop (no generated compose file)."; exit 0; }
  # With no args, default to ALL profiles ("*") so `rydberg down` actually
  # stops everything, not just profile-less services like cloudflared.
  # Pass your own --profile to target a subset instead.
  local flags=("$@")
  if [ "${#flags[@]}" -eq 0 ]; then
    flags=(--profile "*")
  fi
  docker compose -f "$GENERATED" "${flags[@]}" down --remove-orphans
}

cmd_restart() {
  [ -f "$GENERATED" ] || { echo "Nothing running yet — run 'rydberg up' first."; exit 1; }
  if [ "$#" -eq 0 ]; then
    docker compose -f "$GENERATED" restart
  else
    docker compose -f "$GENERATED" restart "$@"
  fi
}

cmd_status() {
  [ -f "$GENERATED" ] || { echo "Nothing running yet — run 'rydberg up' first."; exit 0; }
  docker compose -f "$GENERATED" ps
}

cmd_logs() {
  local name="${1:?service name required (see: rydberg status)}"; shift || true
  [ -f "$GENERATED" ] || { echo "Nothing running yet — run 'rydberg up' first."; exit 1; }
  docker compose -f "$GENERATED" logs "$name" "$@"
}

cmd_doctor() {
  local ok=1
  echo "Checking prerequisites..."

  if command -v docker >/dev/null 2>&1; then
    echo "  [ok] docker is installed ($(docker --version))"
  else
    echo "  [FAIL] docker not found — install Docker first"
    ok=0
  fi

  if docker compose version >/dev/null 2>&1; then
    echo "  [ok] docker compose is available"
  else
    echo "  [FAIL] docker compose not found (need the compose plugin, v2+)"
    ok=0
  fi

  if docker network inspect rydberg-net >/dev/null 2>&1; then
    echo "  [ok] rydberg-net network exists"
  else
    echo "  [warn] rydberg-net network not found — create it with:"
    echo "         docker network create rydberg-net"
  fi

  if [ -f "$ROOT/.env" ]; then
    echo "  [ok] .env exists"
  else
    echo "  [warn] no .env found — copy .env.example to .env and fill it in"
  fi

  if [ -s "$REGISTRY" ]; then
    echo "  [ok] $(wc -l < "$REGISTRY" | tr -d ' ') module(s) registered"
  else
    echo "  [warn] no modules installed yet — see: rydberg install"
  fi

  if [ "$ok" -eq 1 ]; then
    echo "Looks good."
  else
    echo "Fix the FAIL items above before running 'rydberg up'."
    exit 1
  fi
}

cmd_self_install() {
  local target="${1:-/usr/local/bin/rydberg}"
  local src="$ROOT/bin/rydberg"
  if [ -e "$target" ] && [ "$(readlink -f "$target" 2>/dev/null)" != "$src" ]; then
    echo "Something already exists at $target and isn't a link to this script."
    echo "Remove it first, or pass a different target: rydberg self-install <path>"
    exit 1
  fi
  if ln -sf "$src" "$target" 2>/dev/null; then
    echo "Linked $target -> $src"
    echo "You can now run 'rydberg' from anywhere. Try: rydberg doctor"
  else
    echo "Could not write to $target (needs sudo?). Try:"
    echo "  sudo ln -sf \"$src\" \"$target\""
    echo "...or install to somewhere on your PATH you own, e.g.:"
    echo "  mkdir -p ~/.local/bin && ln -sf \"$src\" ~/.local/bin/rydberg"
    exit 1
  fi
}

# --- dispatch -------------------------------------------------------------
case "${1:-}" in
  install) shift; cmd_install "$@" ;;
  catalog) cmd_catalog ;;
  remove)  shift; cmd_remove "$@" ;;
  update)  shift; cmd_update "$@" ;;
  list)    cmd_list ;;
  up)      shift; cmd_up "$@" ;;
  down)    shift; cmd_down "$@" ;;
  restart) shift; cmd_restart "$@" ;;
  status)  cmd_status ;;
  logs)    shift; cmd_logs "$@" ;;
  doctor)  cmd_doctor ;;
  self-install) shift; cmd_self_install "$@" ;;
  *) usage ;;
esac